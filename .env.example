# ============================================================
# AIBOTS - Self-hosted VICIdial AI Voice Platform
# Copy to .env and edit for your Ubuntu server
# ============================================================

# --- Core ---
APP_NAME=AIBOTS
APP_ENV=production
SECRET_KEY=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440
ADMIN_EMAIL=xceedconnections@gmail.com
ADMIN_PASSWORD=Openaccount@123

# --- Database ---
POSTGRES_USER=aibots
POSTGRES_PASSWORD=aibots_secure_pass
POSTGRES_DB=aibots
DATABASE_URL=postgresql+asyncpg://aibots:aibots_secure_pass@postgres:5432/aibots

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# --- Portal ---
# Leave empty to use same-origin /api proxy (recommended)
VITE_API_URL=

# --- AI / Ollama ---
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=qwen2.5:7b-instruct
LLM_TEMPERATURE=0.2

# --- STT (Faster-Whisper) ---
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- TTS (Piper) ---
PIPER_MODEL_PATH=/models/piper/en_US-lessac-medium.onnx
PIPER_CONFIG_PATH=/models/piper/en_US-lessac-medium.onnx.json

# --- VICIdial ---
VICIDIAL_URL=http://YOUR_VICIDIAL_IP/vicidial
VICIDIAL_USER=6666
VICIDIAL_PASS=your_api_pass
VICIDIAL_SOURCE=aibots
ASTERISK_AMI_HOST=YOUR_VICIDIAL_IP
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=aibots
ASTERISK_AMI_SECRET=ami_secret

# --- Worker ---
MAX_CONCURRENT_CALLS=4
AUDIO_SAMPLE_RATE=16000
SILENCE_TIMEOUT_MS=1200
MAX_QUESTION_RETRIES=2
